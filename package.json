{
  "name": "bamboo-spec-parser",
  "version": "0.0.0",
  "description": "A TypeScript library for parsing Bamboo Specs YAML files into structured JavaScript objects.",
  "keywords": [
    "bamboo",
    "specs",
    "parser",
    "typescript",
    "yaml",
    "atlassian",
    "ci"
  ],
  "homepage": "https://github.com/HRAshton/bamboo-spec-parser",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./browser": {
      "import": "./dist/browser.js",
      "types": "./dist/browser.d.ts"
    }
  },
  "types": "./dist/index.d.ts",
  "browser": "./dist/browser.js",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "biome check --error-on-warnings",
    "format": "biome format --write",
    "test": "vitest run --coverage",
    "size": "size-limit"
  },
  "author": "HRAshton",
  "repository": "github:HRAshton/bamboo-spec-parser",
  "bugs": {
    "url": "https://github.com/HRAshton/bamboo-spec-parser/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "size-limit": [
    {
      "path": "dist/browser.js",
      "limit": "3.5 KB"
    }
  ],
  "devDependencies": {
    "@biomejs/biome": "2.2.3",
    "@size-limit/preset-small-lib": "^8.2.4",
    "@types/node": "^22.18.1",
    "@vitest/coverage-istanbul": "3.2.4",
    "size-limit": "^8.2.4",
    "tsdown": "^0.15.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}